# ── ServiceNow Instance ────────────────────────────────────────────────────────
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# ── Authentication ─────────────────────────────────────────────────────────────
# Mode: basic (default) | oauth
SERVICENOW_AUTH_MODE=basic

# Basic Auth credentials (required when AUTH_MODE=basic)
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password

# OAuth credentials (required when AUTH_MODE=oauth)
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# ── HTTP Tuning ────────────────────────────────────────────────────────────────
SERVICENOW_TIMEOUT_SECONDS=30
SERVICENOW_MAX_RETRIES=3
SERVICENOW_RETRY_BACKOFF=1.0

# ── MCP Transport ──────────────────────────────────────────────────────────────
# Transport: stdio (default) | sse
MCP_TRANSPORT=stdio

# SSE settings (only used when MCP_TRANSPORT=sse)
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
